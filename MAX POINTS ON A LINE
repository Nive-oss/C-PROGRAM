#include <vector>
#include <unordered_map>
#include <numeric>
#include <string>

using namespace std;

class Solution {
public:
    int maxPoints(vector<vector<int>>& points) {
        int n = points.size();
        if (n <= 2) return n;
        
        int result = 0;
        
        for (int i = 0; i < n; i++) {
            // Map stores "dy/dx" as a string "dy_dx" to avoid float precision issues
            unordered_map<string, int> counts;
            int local_max = 0;
            
            for (int j = i + 1; j < n; j++) {
                int dy = points[j][1] - points[i][1];
                int dx = points[j][0] - points[i][0];
                
                // Simplify slope using GCD
                int common = gcd(dy, dx);
                dy /= common;
                dx /= common;
                
                // Standardize direction (handle negative signs consistently)
                if (dx < 0) {
                    dx = -dx;
                    dy = -dy;
                } else if (dx == 0) {
                    dy = abs(dy); // Vertical line
                }
                
                string slope = to_string(dy) + "_" + to_string(dx);
                counts[slope]++;
                local_max = max(local_max, counts[slope]);
            }
            // Add 1 to include the pivot point itself
            result = max(result, local_max + 1);
        }
        
        return result;
    }

private:
    int gcd(int a, int b) {
        while (b) {
            a %= b;
            swap(a, b);
        }
        return a;
    }
};
