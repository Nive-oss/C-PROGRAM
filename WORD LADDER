#include <iostream>
#include <vector>
#include <string>
#include <unordered_set>
#include <queue>

using namespace std;

class Solution {
public:
    int ladderLength(string beginWord, string endWord, vector<string>& wordList) {
        // Put wordList into a set for O(1) lookup
        unordered_set<string> dict(wordList.begin(), wordList.end());
        
        // If the endWord isn't in the dictionary, no path exists
        if (dict.find(endWord) == dict.end()) return 0;
        
        // BFS queue: stores {current_word, current_level}
        queue<pair<string, int>> q;
        q.push({beginWord, 1});
        
        while (!q.empty()) {
            string word = q.front().first;
            int level = q.front().second;
            q.pop();
            
            // Try changing every character of the word to 'a'-'z'
            for (int i = 0; i < word.length(); i++) {
                char originalChar = word[i];
                
                for (char c = 'a'; c <= 'z'; c++) {
                    if (c == originalChar) continue;
                    
                    word[i] = c;
                    
                    // If we found the endWord, return the current level + 1
                    if (word == endWord) return level + 1;
                    
                    // If the new word is in the dictionary, add to queue and remove from dict
                    if (dict.find(word) != dict.end()) {
                        q.push({word, level + 1});
                        dict.erase(word); // Marking as visited
                    }
                }
                // Restore the character for the next position loop
                word[i] = originalChar;
            }
        }
        
        return 0; // No path found
    }
};
