#include <vector>
#include <set>
#include <algorithm>

using namespace std;

class SummaryRanges {
private:
    // We store intervals as pairs {start, end}. 
    // The set keeps them sorted by the 'start' value.
    struct Interval {
        int start, end;
        bool operator<(const Interval& other) const {
            return start < other.start;
        }
    };
    set<Interval> intervals;

public:
    SummaryRanges() {}

    void addNum(int value) {
        // Find the first interval with start > value
        auto it = intervals.lower_bound({value, value});
        
        int start = value, end = value;

        // 1. Check if it can merge with the interval to its right
        if (it != intervals.end() && it->start == value + 1) {
            end = it->end;
            it = intervals.erase(it);
        }

        // 2. Check if it can merge with the interval to its left
        if (it != intervals.begin()) {
            auto prev = std::prev(it);
            // If value is already covered by the previous interval, just return
            if (prev->end >= value) {
                return;
            }
            // If value is exactly one after the previous interval, merge them
            if (prev->end == value - 1) {
                start = prev->start;
                intervals.erase(prev);
            }
        }

        intervals.insert({start, end});
    }

    vector<vector<int>> getIntervals() {
        vector<vector<int>> result;
        for (const auto& interval : intervals) {
            result.push_back({interval.start, interval.end});
        }
        return result;
    }
};
