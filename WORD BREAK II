#include <vector>
#include <string>
#include <unordered_map>

using namespace std;

class Solution {
    unordered_map<string, vector<string>> memo;

public:
    vector<string> wordBreak(string s, vector<string>& wordDict) {
        // If we've already solved for this suffix, return the cached result
        if (memo.count(s)) return memo[s];
        
        // Base case: if string is empty
        if (s.empty()) return {""};

        vector<string> res;
        for (const string& word : wordDict) {
            // Check if the current word matches the start of string s
            if (s.substr(0, word.length()) == word) {
                // Recursively find all sentences for the remaining part
                vector<string> subSentences = wordBreak(s.substr(word.length()), wordDict);
                
                // Combine current word with the suffixes found
                for (const string& sub : subSentences) {
                    res.push_back(word + (sub.empty() ? "" : " ") + sub);
                }
            }
        }

        return memo[s] = res;
    }
};
