#include <vector>
#include <unordered_map>
#include <unordered_set>
#include <random>

using namespace std;

class RandomizedCollection {
private:
    vector<int> nums;
    // Maps the value to a set of its indices in the 'nums' vector
    unordered_map<int, unordered_set<int>> valToIndices;

public:
    RandomizedCollection() {}

    bool insert(int val) {
        bool notPresent = valToIndices[val].empty();
        
        // Add to vector and record the index
        valToIndices[val].insert(nums.size());
        nums.push_back(val);
        
        return notPresent;
    }

    bool remove(int val) {
        if (valToIndices[val].empty()) return false;

        // 1. Get an arbitrary index of the value to remove
        int indexToRemove = *valToIndices[val].begin();
        valToIndices[val].erase(indexToRemove);

        int lastIdx = nums.size() - 1;
        int lastVal = nums[lastIdx];

        // 2. If the element is not the last one, swap it with the last one
        if (indexToRemove < lastIdx) {
            nums[indexToRemove] = lastVal;
            // Update the index set for the value that was moved
            valToIndices[lastVal].erase(lastIdx);
            valToIndices[lastVal].insert(indexToRemove);
        }

        // 3. Remove the last element
        nums.pop_back();

        return true;
    }

    int getRandom() {
        // Uniform distribution ensures linear probability based on counts
        return nums[rand() % nums.size()];
    }
};
