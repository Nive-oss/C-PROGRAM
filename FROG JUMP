#include <vector>
#include <unordered_map>
#include <unordered_set>

using namespace std;

class Solution {
    // Memoization table: maps (current_index, last_jump) to a boolean result
    // Using a simple map or a 2D array if constraints permit
    unordered_map<int, unordered_set<int>> memo;

public:
    bool canCross(vector<int>& stones) {
        // Initial check: the first jump MUST be exactly 1 unit
        if (stones[1] != 1) return false;
        
        // Map to quickly find index of a stone position
        unordered_map<int, int> stoneIdx;
        for (int i = 0; i < stones.size(); i++) {
            stoneIdx[stones[i]] = i;
        }
        
        return solve(stones, stoneIdx, 1, 1);
    }
    
    bool solve(vector<int>& stones, unordered_map<int, int>& stoneIdx, int currIdx, int k) {
        // Base Case: Reached the last stone
        if (currIdx == stones.size() - 1) return true;
        
        // Memoization check: store as (index * large_prime + jump) or similar
        // For simplicity in C++, we use a map of sets to track (index -> possible jumps)
        if (memo[currIdx].count(k)) return false;

        // Try the three possible jump distances: k-1, k, k+1
        for (int nextK = k - 1; nextK <= k + 1; nextK++) {
            if (nextK <= 0) continue; // Only forward jumps > 0
            
            int nextPos = stones[currIdx] + nextK;
            if (stoneIdx.count(nextPos)) {
                if (solve(stones, stoneIdx, stoneIdx[nextPos], nextK)) return true;
            }
        }
        
        // Mark this state as failing
        memo[currIdx].insert(k);
        return false;
    }
};
